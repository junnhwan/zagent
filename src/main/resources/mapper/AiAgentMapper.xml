<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="io.wanjune.zagent.mapper.AiAgentMapper">

    <resultMap id="BaseResultMap" type="io.wanjune.zagent.model.entity.AiAgent">
        <id column="id" property="id"/>
        <result column="agent_id" property="agentId"/>
        <result column="agent_name" property="agentName"/>
        <result column="description" property="description"/>
        <result column="channel" property="channel"/>
        <result column="strategy" property="strategy"/>
        <result column="status" property="status"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <select id="selectByAgentId" resultMap="BaseResultMap">
        SELECT * FROM ai_agent WHERE agent_id = #{agentId} AND status = 1
    </select>

    <select id="selectAll" resultMap="BaseResultMap">
        SELECT * FROM ai_agent WHERE status = 1
    </select>

    <select id="selectAllIncludeDisabled" resultMap="BaseResultMap">
        SELECT * FROM ai_agent ORDER BY create_time DESC
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO ai_agent (agent_id, agent_name, description, channel, strategy, status)
        VALUES (#{agentId}, #{agentName}, #{description}, #{channel}, #{strategy}, IFNULL(#{status}, 1))
    </insert>

    <update id="update">
        UPDATE ai_agent
        <set>
            <if test="agentName != null">agent_name = #{agentName},</if>
            <if test="description != null">description = #{description},</if>
            <if test="channel != null">channel = #{channel},</if>
            <if test="strategy != null">strategy = #{strategy},</if>
            <if test="status != null">status = #{status},</if>
            update_time = NOW()
        </set>
        WHERE agent_id = #{agentId}
    </update>

    <delete id="deleteByAgentId">
        DELETE FROM ai_agent WHERE agent_id = #{agentId}
    </delete>

</mapper>
