<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="io.wanjune.zagent.mapper.AiClientAdvisorMapper">

    <resultMap id="BaseResultMap" type="io.wanjune.zagent.model.entity.AiClientAdvisor">
        <id column="id" property="id"/>
        <result column="advisor_id" property="advisorId"/>
        <result column="advisor_name" property="advisorName"/>
        <result column="advisor_type" property="advisorType"/>
        <result column="order_num" property="orderNum"/>
        <result column="ext_param" property="extParam"/>
        <result column="status" property="status"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <select id="selectByAdvisorId" resultMap="BaseResultMap">
        SELECT * FROM ai_client_advisor WHERE advisor_id = #{advisorId} AND status = 1
    </select>

    <select id="selectByAdvisorIds" resultMap="BaseResultMap">
        SELECT * FROM ai_client_advisor WHERE status = 1 AND advisor_id IN
        <foreach collection="advisorIds" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
        ORDER BY order_num ASC
    </select>

    <select id="selectAll" resultMap="BaseResultMap">
        SELECT * FROM ai_client_advisor ORDER BY create_time DESC
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO ai_client_advisor (advisor_id, advisor_name, advisor_type, order_num, ext_param, status)
        VALUES (#{advisorId}, #{advisorName}, #{advisorType}, #{orderNum}, #{extParam}, IFNULL(#{status}, 1))
    </insert>

    <update id="update">
        UPDATE ai_client_advisor
        <set>
            <if test="advisorName != null">advisor_name = #{advisorName},</if>
            <if test="advisorType != null">advisor_type = #{advisorType},</if>
            <if test="orderNum != null">order_num = #{orderNum},</if>
            <if test="extParam != null">ext_param = #{extParam},</if>
            <if test="status != null">status = #{status},</if>
            update_time = NOW()
        </set>
        WHERE advisor_id = #{advisorId}
    </update>

    <delete id="deleteByAdvisorId">
        DELETE FROM ai_client_advisor WHERE advisor_id = #{advisorId}
    </delete>

</mapper>
