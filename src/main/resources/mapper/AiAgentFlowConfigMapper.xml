<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="io.wanjune.zagent.mapper.AiAgentFlowConfigMapper">

    <resultMap id="BaseResultMap" type="io.wanjune.zagent.model.entity.AiAgentFlowConfig">
        <id column="id" property="id"/>
        <result column="agent_id" property="agentId"/>
        <result column="client_id" property="clientId"/>
        <result column="client_type" property="clientType"/>
        <result column="sequence" property="sequence"/>
        <result column="step_prompt" property="stepPrompt"/>
        <result column="create_time" property="createTime"/>
    </resultMap>

    <select id="selectByAgentId" resultMap="BaseResultMap">
        SELECT * FROM ai_agent_flow_config WHERE agent_id = #{agentId} ORDER BY sequence ASC
    </select>

    <select id="selectAll" resultMap="BaseResultMap">
        SELECT * FROM ai_agent_flow_config
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO ai_agent_flow_config (agent_id, client_id, client_type, sequence, step_prompt)
        VALUES (#{agentId}, #{clientId}, #{clientType}, #{sequence}, #{stepPrompt})
    </insert>

    <update id="update">
        UPDATE ai_agent_flow_config
        <set>
            <if test="clientId != null">client_id = #{clientId},</if>
            <if test="clientType != null">client_type = #{clientType},</if>
            <if test="sequence != null">sequence = #{sequence},</if>
            <if test="stepPrompt != null">step_prompt = #{stepPrompt},</if>
        </set>
        WHERE id = #{id}
    </update>

    <delete id="deleteById">
        DELETE FROM ai_agent_flow_config WHERE id = #{id}
    </delete>

    <delete id="deleteByAgentId">
        DELETE FROM ai_agent_flow_config WHERE agent_id = #{agentId}
    </delete>

</mapper>
