<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="io.wanjune.zagent.mapper.AiClientSystemPromptMapper">

    <resultMap id="BaseResultMap" type="io.wanjune.zagent.model.entity.AiClientSystemPrompt">
        <id column="id" property="id"/>
        <result column="prompt_id" property="promptId"/>
        <result column="prompt_name" property="promptName"/>
        <result column="prompt_content" property="promptContent"/>
        <result column="description" property="description"/>
        <result column="status" property="status"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <select id="selectByPromptId" resultMap="BaseResultMap">
        SELECT * FROM ai_client_system_prompt WHERE prompt_id = #{promptId} AND status = 1
    </select>

    <select id="selectByPromptIds" resultMap="BaseResultMap">
        SELECT * FROM ai_client_system_prompt WHERE status = 1 AND prompt_id IN
        <foreach collection="promptIds" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </select>

    <select id="selectAll" resultMap="BaseResultMap">
        SELECT * FROM ai_client_system_prompt ORDER BY create_time DESC
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO ai_client_system_prompt (prompt_id, prompt_name, prompt_content, description, status)
        VALUES (#{promptId}, #{promptName}, #{promptContent}, #{description}, IFNULL(#{status}, 1))
    </insert>

    <update id="update">
        UPDATE ai_client_system_prompt
        <set>
            <if test="promptName != null">prompt_name = #{promptName},</if>
            <if test="promptContent != null">prompt_content = #{promptContent},</if>
            <if test="description != null">description = #{description},</if>
            <if test="status != null">status = #{status},</if>
            update_time = NOW()
        </set>
        WHERE prompt_id = #{promptId}
    </update>

    <delete id="deleteByPromptId">
        DELETE FROM ai_client_system_prompt WHERE prompt_id = #{promptId}
    </delete>

</mapper>
