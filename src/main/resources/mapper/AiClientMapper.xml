<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="io.wanjune.zagent.mapper.AiClientMapper">

    <resultMap id="BaseResultMap" type="io.wanjune.zagent.model.entity.AiClient">
        <id column="id" property="id"/>
        <result column="client_id" property="clientId"/>
        <result column="client_name" property="clientName"/>
        <result column="description" property="description"/>
        <result column="status" property="status"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <select id="selectByClientId" resultMap="BaseResultMap">
        SELECT * FROM ai_client WHERE client_id = #{clientId} AND status = 1
    </select>

    <select id="selectAll" resultMap="BaseResultMap">
        SELECT * FROM ai_client ORDER BY create_time DESC
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO ai_client (client_id, client_name, description, status)
        VALUES (#{clientId}, #{clientName}, #{description}, IFNULL(#{status}, 1))
    </insert>

    <update id="update">
        UPDATE ai_client
        <set>
            <if test="clientName != null">client_name = #{clientName},</if>
            <if test="description != null">description = #{description},</if>
            <if test="status != null">status = #{status},</if>
            update_time = NOW()
        </set>
        WHERE client_id = #{clientId}
    </update>

    <delete id="deleteByClientId">
        DELETE FROM ai_client WHERE client_id = #{clientId}
    </delete>

</mapper>
